---
layout: layout.njk
title: Home
---

<p>{{ site.bio }}</p>

<h2>Posts</h2>
<ul class="post-list">
  {% for post in collections.posts %}
  <li>
    <a href="{{ post.url }}">{{ post.data.title }}</a>
    <time datetime="{{ post.date | date('yyyy-MM-dd') }}">{{ post.date | date('yyyy-MM-dd') }}</time>
  </li>
  {% endfor %}
</ul>
